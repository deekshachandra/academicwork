
1. Create a table for jewelry pieces
CREATE TABLE jewelry_collection (
    piece_id INT PRIMARY KEY,
    piece_name VARCHAR(100),
    material VARCHAR(50),
    collection_name VARCHAR(100),
    price DECIMAL(10,2),
    launch_date DATE
);

