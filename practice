-- 3. Find the high-value queens (over $500)
SELECT piece_name, price
FROM jewelry_collection
WHERE price > 500
ORDER BY price DESC;

-- 4. Count how many silver pieces we adore
SELECT material, COUNT(*) AS total_pieces
FROM jewelry_collection
GROUP BY material;

-- 5. Calculate average sparkle investment
SELECT AVG(price) AS average_price
FROM jewelry_collection;
